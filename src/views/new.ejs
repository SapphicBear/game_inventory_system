<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head.ejs"); %>
</head>
<body>
    <div class="wrapper new">
        <header>
            <%- include("./partials/header.ejs"); %>
        </header>
        <main class="new">
            <form action="/new" method="POST" class="new-form">
                <fieldset>
                        <legend>Item information</legend>
                <div class="new form-row">
                    <label for="name">Title: </label>
                    <input type="text" name="name" id="name">
                </div>
                <div class="new form-row">
                    <label for="genre">Genre: </label>
                    <input type="text" name="genre" id="genre">
                </div>
                <div class="new form-row">
                    <label for="studio">Game Studio: </label>
                    <input type="text" name="studio" id="studio">
                </div>
                <div class="new form-row">
                    <label for="release_year">Release year: </label>
                    <input type="text" name="release_year" id="release_year">
                </div>
                </fieldset>
                <fieldset>
                    <legend>Store information</legend>
                <div class="new form-row">
                    <label for="console">Available on: </label>
                    <div class="console-area">
                    <select name="console" id="console">
                        <option value="" selected disabled hidden>Select a Console</option>
                        <% consoles.map((console) => { %>
                            <option value="<%= console.name %>"><%= console.name %></option>
                        <% }); %>
                    </select>
                    
                    </div>
                    <!-- TODO: add multi select for consoles, can remove existing ones -->
                </div>
                <div class="new form-row">
                    <label for="in_stock">In Stock: </label>
                    <input type="number" name="in_stock" id="in_stock" placeholder="0">
                </div>
                <div class="new form-row">
                    <label for="price">Price: </label>
                    <input type="tel" name="price" id="price" placeholder="0.00">
                </div>
                </fieldset>
                <button type="submit">Submit</button>
                <button type="button">Cancel</button>
            </form>
            <aside>
                <ul>
                    <% if (errors) { %>
                <% errors.map((error) => { %>
                    <li><%= error.msg %></li>
                <% }); %>
                <%}%>
                </ul>
        </aside>
        </main>
        
        <footer>
            <%- include("./partials/footer.ejs", { links: links }); %>
        </footer>
    </div>
</body>
</html>