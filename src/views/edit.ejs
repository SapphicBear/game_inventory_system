<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head.ejs"); %>
</head>
<body>
    <div class="wrapper edit">
        <header>
            <%- include("./partials/header.ejs"); %>
        </header>
        <main class="edit">
            <form action="/edit" method="UPDATE" class="edit-form">
                <% game.map((data) => { %>
                    <fieldset>
                        <legend>Item information</legend>
                <div class="edit form-row">
                    <label for="title">Title: </label>
                    <input type="text" name="title" id="title" value="<%= data.game_name %>">
                </div>
                <div class="edit form-row">
                    <label for="genre">Genre: </label>
                    <input type="text" name="genre" id="genre" value="<%= data.genre %>">
                </div>
                <div class="edit form-row">
                    <label for="studio">Game Studio: </label>
                    <input type="text" name="studio" id="studio" value="<%= data.studio_name %>">
                </div>
                <div class="edit form-row">
                    <label for="release">Release year: </label>
                    <input type="text" name="release" id="release" value="<%= data.release_year %>">
                </div>
                </fieldset>
                <fieldset>
                    <legend>Store information</legend>
                <div class="edit form-row">
                    <label for="consoles">Available on: </label>
                    <div class="console-area">
                    <% data.console.map((con) => { %>
                        <input type="text" id="<%= con %>" value="<%= con.replaceAll("_", " ") %>">
                        <!-- <button type="button" class="delete-button">X</button> -->
                    <% }); %>
                    </div>
                    <!-- TODO: add multi select for consoles, can remove existing ones -->
                </div>
                <div class="edit form-row">
                    <label for="inStock">In Stock: </label>
                    <input type="number" name="inStock" id="inStock" value="<%= data.in_stock %>">
                </div>
                <div class="edit form-row">
                    <label for="price">Price: </label>
                    <input type="tel" name="price" id="price" value="<%= data.price %>">
                </div>
                </fieldset>
                <% }); %>
                <button type="submit">Submit Changes</button>
                <button type="button">Cancel</button>
            </form>
        </main>
        <footer>
            <%- include("./partials/footer.ejs", { links: links }); %>
        </footer>
    </div>
</body>
</html>