<% games.map((game) => { %>
    <li>
        <div class="gameContainer">
            <div class="game-info">
                <h2><%= game.game_name %></h2>
                <div class="game-desc">
                <p>Studio: <%= game.studio_name %></p>
                <p>Genre: <%= game.genre %></p>
                <p>Released: <%= game.release_year %></p>
                <p>Available on: <%= game.console %></p>
                </div>
            </div>
            <div class="<%= game.in_stock !== 0 ? "available" : "not-available" %>">
                <h3><%= game.in_stock %></h3>
                <p><%= game.in_stock !== 0 ? "Available" : "Not Available" %></p>
            </div>
            <p><%= game.id %></p>
            <p>$<%= game.price %></p>
            <a class="edit-button" href="/edit/<%= game.id %>">Edit</a>
            
        </div>
    </li>
<% }); %>